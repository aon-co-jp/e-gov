# 実際の値はコミットしないこと(.envはgitignore対象)。
# LINE Developersコンソールで発行される値をここに設定する。
# 未設定の間はWebhookが「未接続」を返すのみで実際の送受信は行わない。
E_GOV_LINE_CHANNEL_SECRET=
E_GOV_LINE_CHANNEL_ACCESS_TOKEN=

# 以下は任意設定(未設定時は既定値が使われる)。

# 掲示板(/board)の投稿保持時間(時間単位、既定72)。
E_GOV_BOARD_RETENTION_HOURS=

# 定期自動調査・自動マーケティングドラフト生成の実行間隔(時間単位、
# 既定はそれぞれ24/12)。
E_GOV_RESEARCH_INTERVAL_HOURS=
E_GOV_MARKETING_INTERVAL_HOURS=

# 定期実行の生成物(research-report.json/marketing-drafts.json)の
# 書き出し先ディレクトリ(既定はカレントディレクトリ)。
E_GOV_DATA_DIR=
